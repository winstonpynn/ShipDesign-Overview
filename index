function selectCourse(id, termId, stream, fromHolding) {
  selectedCourseId = id;
  selectedTermId = termId;
  selectedStream = stream;
  selectedFromHolding = fromHolding;
  openDetailView(id);
}

function updateEditPanel() {
  const panel = document.getElementById('edit-panel');
  if (!selectedCourseId) { panel.classList.remove('visible'); return; }

  const course = findCourse(selectedCourseId);
  if (!course) { panel.classList.remove('visible'); return; }

  panel.classList.add('visible');

  const moveBtn = document.getElementById('btn-move-to-holding');
  moveBtn.style.display = selectedFromHolding ? 'none' : 'block';

  const loc = selectedFromHolding ? 'Holding Area' : `${selectedTermId} · ${STREAM_LABELS[selectedStream]}`;
  document.getElementById('edit-location').textContent = 'Location: ' + loc;

  document.getElementById('edit-code').value  = course.code;
  document.getElementById('edit-title').value = course.title;
  document.getElementById('edit-lect').value  = course.lect;
  document.getElementById('edit-lab').value   = course.lab;
  document.getElementById('edit-stream').value = course.stream;
  document.getElementById('edit-notes').value  = course.notes || '';
}

on('btn-apply-edit', 'click', () => {
  if (!selectedCourseId) return;
  const course = findCourse(selectedCourseId);
  if (!course) return;
  course.code   = document.getElementById('edit-code').value.trim();
  course.title  = document.getElementById('edit-title').value.trim();
  course.lect   = parseInt(document.getElementById('edit-lect').value) || 0;
  course.lab    = parseInt(document.getElementById('edit-lab').value) || 0;
  course.stream = document.getElementById('edit-stream').value;
  course.notes  = document.getElementById('edit-notes').value.trim();
  render();
  updateEditPanel();
});

on('btn-move-to-holding', 'click', () => {
  if (!selectedCourseId) return;
  if (selectedFromHolding) return; // already in holding
  const course = findCourse(selectedCourseId);
  if (!course) return;
  grid[selectedTermId][selectedStream] = grid[selectedTermId][selectedStream].filter(x => x.id !== selectedCourseId);
  holding.push(course);
  // Open holding drawer so user sees it land
  document.getElementById('holding-drawer').classList.remove('collapsed');
  selectedCourseId = null;
  document.getElementById('edit-panel').classList.remove('visible');
  render();
});

on('btn-remove-course', 'click', () => {
  if (!selectedCourseId) return;
  const course = findCourse(selectedCourseId);
  if (!course) return;
  if (!confirm(`Permanently delete "${course.title}"?\n\nThis cannot be undone. Use "Move to Holding" instead to keep the course available.`)) return;
  if (selectedFromHolding) {
    holding = holding.filter(x => x.id !== selectedCourseId);
  } else {
    grid[selectedTermId][selectedStream] = grid[selectedTermId][selectedStream].filter(x => x.id !== selectedCourseId);
  }
  selectedCourseId = null;
  document.getElementById('edit-panel').classList.remove('visible');
  render();
});

on('edit-panel-close', 'click', () => {
  selectedCourseId = null;
  document.getElementById('edit-panel').classList.remove('visible');
  render();
});

// Click away to deselect — but not if detail overlay is open
document.addEventListener('click', (e) => {
  if (document.getElementById('detail-overlay').classList.contains('visible')) return;
  if (!e.target.closest('.course-block') && !e.target.closest('#edit-panel')) {
    selectedCourseId = null;
    document.getElementById('edit-panel').classList.remove('visible');
    render();
  }
});


