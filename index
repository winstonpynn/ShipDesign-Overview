  // Tab: Accreditation
  renderGATable(course.gaMappings || {});
  document.getElementById('d-naty').value = course.natyNotes || '';
  document.getElementById('d-ahep').value = course.ahepNotes || '';

  // Tab: Status
  document.querySelectorAll('.status-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.val === (course.outlineStatus || 'not-started'));
  });
  document.getElementById('d-edited-by').value    = course.editedBy    || '';
  document.getElementById('d-edited-date').value  = course.editedDate  || '';
  document.getElementById('d-review-notes').value = course.reviewNotes || '';

  // Tab: Relationships
  renderTags('d-prereq-tags', course.prereqs || [], 'prereq');
  renderTags('d-coreq-tags',  course.coreqs  || [], 'coreq');
  document.getElementById('d-replaces').value      = course.replaces   || '';
  document.getElementById('d-replaced-by').value   = course.replacedBy || '';
  document.getElementById('d-src-narc').checked    = !!course.srcNarc;
  document.getElementById('d-src-mmd').checked     = !!course.srcMmd;
  document.getElementById('d-src-new').checked     = !!course.srcNew;

