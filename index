  .task-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
  .task-form-row.three { grid-template-columns: 1fr 1fr 1fr; }
  .task-form-group label {
    display: block; font-size: 10px; font-weight: 700;
    letter-spacing: 0.07em; text-transform: uppercase;
    color: var(--text-muted); margin-bottom: 4px;
  }
  .task-form-group input, .task-form-group select, .task-form-group textarea {
    width: 100%; padding: 6px 9px; border: 1px solid var(--border);
    border-radius: 4px; font-family: 'IBM Plex Sans', sans-serif;
    font-size: 12px; background: #fff; color: var(--text);
  }
  .task-form-group textarea { min-height: 55px; resize: vertical; }
  .btn-add-task {
    background: var(--accent); color: #fff; border: none; border-radius: 4px;
