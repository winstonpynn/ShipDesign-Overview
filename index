  document.getElementById('d-lect').value        = course.lect;
  document.getElementById('d-lab').value         = course.lab;
  document.getElementById('d-stream').value      = course.stream;
  document.getElementById('d-delivery').value    = course.delivery    || '';
  document.getElementById('d-description').value = course.description || '';
  document.getElementById('d-notes').value       = course.notes       || '';

  // Tab: Outline
  renderDetailTopics(course.topics || []);
  document.getElementById('d-assess-assign').value = course.assessAssign || 0;
  document.getElementById('d-assess-mid').value    = course.assessMid    || 0;
  document.getElementById('d-assess-final').value  = course.assessFinal  || 0;
  document.getElementById('d-assess-lab').value    = course.assessLab    || 0;
  document.getElementById('d-assess-other').value  = course.assessOther  || 0;
  document.getElementById('d-resources').value     = course.resources    || '';
