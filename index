function render() {
  const grid_el = document.getElementById('program-grid');
  grid_el.innerHTML = '';

  let prevStage = null;

  TERMS.forEach(term => {
    // Stage divider
    if (STAGE_DIVIDERS[term.id]) {
      const div = document.createElement('div');
      div.className = 'stage-label';
      div.textContent = STAGE_DIVIDERS[term.id].label;
      grid_el.appendChild(div);
    }

    const row = document.createElement('div');
    row.className = 'term-row';

    // Calculate contact hours for this term
    let totalLect = 0, totalLab = 0;
    STREAMS.forEach(s => {
      grid[term.id][s].forEach(c => {
        totalLect += (c.lect || 0);
        totalLab  += (c.lab  || 0);
      });
    });
    const totalCH = (totalLect + totalLab) * term.weeks;

    // Term header
    const hdr = document.createElement('div');
    hdr.className = 'term-header' + (term.ts ? ' ts-term' : '');
    hdr.innerHTML = `
      <div>
        <div class="term-name">${term.label}</div>
        <div class="term-subtitle">${term.subtitle}</div>
      </div>
      <div class="term-ch"><span class="ch-label">CH </span>${totalLect+totalLab}<span class="ch-label">/wk</span></div>
    `;
    row.appendChild(hdr);

    // Stream cells
    STREAMS.forEach(stream => {
      const cell = document.createElement('div');
      cell.className = 'stream-cell';
      cell.dataset.term = term.id;
      cell.dataset.stream = stream;

      grid[term.id][stream].forEach((course, idx) => {
        cell.appendChild(makeCourseBlock(course, term.id, stream, idx));
      });

      // Drop events
      cell.addEventListener('dragover', onCellDragOver);
      cell.addEventListener('dragleave', onCellDragLeave);
      cell.addEventListener('drop', onCellDrop);

      row.appendChild(cell);
    });

    grid_el.appendChild(row);
  });

  renderHolding();
}

function makeCourseBlock(course, termId, stream, idx) {
  const el = document.createElement('div');
  const status = course.outlineStatus || 'not-started';
  el.className = 'course-block ' + course.stream + ' status-' + status;
  el.dataset.id = course.id;
  if (course.id === selectedCourseId) el.classList.add('selected');

  const isNew = course.code.startsWith('[') || (course.notes || '').includes('[New');
  el.innerHTML = `
    <div class="cb-code">${escHtml(course.code)}</div>
    <div class="cb-title">${escHtml(course.title)}</div>
    <div class="cb-hours">${course.lect}L + ${course.lab}Lab</div>
    ${isNew ? '<span class="cb-new-badge">NEW</span>' : ''}
    <div class="cb-status-stripe"></div>
  `;
  el.draggable = false;
  el.style.cursor = 'pointer';
  el.addEventListener('click', (e) => { e.stopPropagation(); selectCourse(course.id, termId, stream, false); });
  return el;
}

function renderHolding() {
  const area = document.getElementById('holding-area');
  const count = document.getElementById('holding-count');
  area.innerHTML = '';

  if (holding.length === 0) {
    area.innerHTML = '<span class="holding-empty">Empty — drag courses here or displace them by dropping onto an occupied slot</span>';
  } else {
    // Sort by stream then code
    const sorted = [...holding].sort((a,b) => STREAMS.indexOf(a.stream) - STREAMS.indexOf(b.stream) || a.code.localeCompare(b.code));
    sorted.forEach((course, idx) => {
      const el = makeCourseBlockHolding(course, idx);
      area.appendChild(el);
    });
  }
  count.textContent = holding.length;

  // Holding drop zone
  area.addEventListener('dragover', onHoldingDragOver);
  area.addEventListener('dragleave', onHoldingDragLeave);
  area.addEventListener('drop', onHoldingDrop);
}

function makeCourseBlockHolding(course, idx) {
  const el = document.createElement('div');
  const status = course.outlineStatus || 'not-started';
  el.className = 'course-block ' + course.stream + ' status-' + status;
  el.dataset.id = course.id;
  if (course.id === selectedCourseId) el.classList.add('selected');
  const isNew = course.code.startsWith('[') || (course.notes || '').includes('[New');
  el.innerHTML = `
    <div class="cb-code">${escHtml(course.code)}</div>
    <div class="cb-title">${escHtml(course.title)}</div>
    <div class="cb-hours">${course.lect}L + ${course.lab}Lab</div>
    ${isNew ? '<span class="cb-new-badge">NEW</span>' : ''}
    <div class="cb-status-stripe"></div>
  `;
  el.draggable = true;
  el.addEventListener('dragstart', (e) => onBlockDragStart(e, course.id, null, null, idx, true));
  el.addEventListener('dragend', onBlockDragEnd);
  el.addEventListener('click', (e) => { e.stopPropagation(); selectCourse(course.id, null, null, true); });
  return el;
}


