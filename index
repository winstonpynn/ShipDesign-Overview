// ── RENDER BOARD ──
function renderBoard() {
  const cols = { todo: [], inprog: [], done: [] };
  tasks.forEach(t => { if (cols[t.status]) cols[t.status].push(t); });

  ['todo','inprog','done'].forEach(status => {
    const container = document.getElementById('col-' + status + '-cards');
    document.getElementById('cnt-' + status).textContent = cols[status].length;
    container.innerHTML = '';
    cols[status].forEach(task => container.appendChild(makeTaskCard(task)));
  });

  // Update toolbar badge
  const open = tasks.filter(t => t.status !== 'done').length;
  document.getElementById('task-count-badge').textContent =
    tasks.length ? `${open} open · ${tasks.length} total` : '';
}

function makeTaskCard(task) {
  const card = document.createElement('div');
  card.className = 'task-card type-' + task.type;
  const member = roster.find(m => m.id === task.assigneeId);
  const assigneeHtml = member
    ? `<span class="task-assignee">${escHtml(member.name)}</span>`
    : `<span class="task-assignee" style="opacity:0.5">Unassigned</span>`;
  const refHtml = task.ref
    ? `<span class="task-ref">${escHtml(task.ref)}</span>` : '';
  const today = new Date().toISOString().slice(0,10);
  const dueHtml = task.due
    ? `<span class="task-due ${task.due < today && task.status !== 'done' ? 'overdue' : ''}">${task.due}</span>`
    : '';

  // Move buttons — show contextual next step
  let moveBtns = '';
  if (task.status === 'todo')   moveBtns = `<button class="task-move-btn" data-id="${task.id}" data-to="inprog">→ In Progress</button>`;
  if (task.status === 'inprog') moveBtns = `<button class="task-move-btn" data-id="${task.id}" data-to="todo">← To Do</button><button class="task-move-btn" data-id="${task.id}" data-to="done">✓ Done</button>`;
  if (task.status === 'done')   moveBtns = `<button class="task-move-btn" data-id="${task.id}" data-to="inprog">↩ Reopen</button>`;

  card.innerHTML = `
    <div class="task-card-actions">
      <button class="task-action-btn" data-delete="${task.id}" title="Delete">✕</button>
    </div>
    <div class="task-card-type">${escHtml(TASK_TYPE_LABELS[task.type] || task.type)}</div>
    <div class="task-card-title">${escHtml(task.title)}</div>
    ${task.desc ? `<div class="task-card-desc">${escHtml(task.desc)}</div>` : ''}
    <div class="task-card-meta">${assigneeHtml}${refHtml}${dueHtml}</div>
    <div class="task-move-btns">${moveBtns}</div>
  `;

  card.querySelectorAll('.task-move-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const t = tasks.find(x => x.id === btn.dataset.id);
      if (t) { t.status = btn.dataset.to; renderBoard(); renderGrid(); }
    });
  });
  card.querySelectorAll('[data-delete]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (confirm('Delete this task?')) {
        tasks = tasks.filter(x => x.id !== btn.dataset.delete);
        renderBoard(); renderGrid();
      }
    });
  });
  return card;
}

// ── CREATE TASK ──
on('btn-create-task', 'click', () => {
  const title = document.getElementById('nt-title').value.trim();
  if (!title) { alert('Title is required.'); return; }

  const assigneeVal = document.getElementById('nt-assignee').value;
  tasks.push({
    id:         taskUid(),
    type:       document.getElementById('nt-type').value,
    title,
    ref:        document.getElementById('nt-ref').value.trim(),
    desc:       document.getElementById('nt-desc').value.trim(),
    assigneeId: assigneeVal || null,
    due:        document.getElementById('nt-due').value,
    status:     document.getElementById('nt-status').value,
  });

  // Clear form
  ['nt-title','nt-ref','nt-desc','nt-due'].forEach(id =>
    document.getElementById(id).value = '');
  document.getElementById('nt-type').value   = 'course-outline';
  document.getElementById('nt-status').value = 'todo';

  renderBoard();
  renderGrid();
  switchTaskTab('board');
});

// ── ROSTER ──
function renderRoster() {
  const list = document.getElementById('roster-list');
  list.innerHTML = '';
  if (roster.length === 0) {
    list.innerHTML = '<p style="font-size:12px;color:var(--text-muted);padding:8px 0;">No team members yet. Add one below.</p>';
    return;
  }
  roster.forEach(member => {
    const taskCount = tasks.filter(t => t.assigneeId === member.id).length;
    const initials = member.name.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
    const div = document.createElement('div');
    div.className = 'roster-member';
    div.innerHTML = `
      <div class="roster-avatar">${escHtml(initials)}</div>
      <div style="flex:1">
        <div class="roster-name">${escHtml(member.name)}</div>
        <div class="roster-role">${escHtml(member.role || '—')}</div>
      </div>
      <span class="roster-task-count">${taskCount} task${taskCount !== 1 ? 's' : ''}</span>
      <button class="roster-remove" data-id="${member.id}" title="Remove">✕</button>
    `;
    div.querySelector('.roster-remove').addEventListener('click', e => {
      if (confirm(`Remove ${member.name} from the roster?\nTheir tasks will become unassigned.`)) {
        tasks.forEach(t => { if (t.assigneeId === member.id) t.assigneeId = null; });
        roster = roster.filter(m => m.id !== e.target.dataset.id);
        renderRoster(); renderBoard(); refreshAssigneeDropdown();
      }
    });
    list.appendChild(div);
  });
}

function refreshAssigneeDropdown() {
  const sel = document.getElementById('nt-assignee');
  const cur = sel.value;
  sel.innerHTML = '<option value="">— Unassigned —</option>';
  roster.forEach(m => {
    const opt = document.createElement('option');
    opt.value = m.id; opt.textContent = m.name;
    if (m.id === cur) opt.selected = true;
    sel.appendChild(opt);
  });
}

on('btn-add-member', 'click', () => {
  const name = document.getElementById('new-member-name').value.trim();
  if (!name) { alert('Name is required.'); return; }
  const role = document.getElementById('new-member-role').value.trim();
  roster.push({ id: 'r' + Date.now(), name, role });
  document.getElementById('new-member-name').value = '';
  document.getElementById('new-member-role').value = '';
  renderRoster(); refreshAssigneeDropdown();
});

