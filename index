<body>

<!-- TOOLBAR -->
<div id="toolbar">
  <h1>NEW SHIP DESIGN PROGRAM <span>— Program Overview</span></h1>
  <span id="last-updated" style="font-size:11px;opacity:0.7;font-family:'IBM Plex Mono',monospace;margin-right:8px;"></span>
  <span style="font-size:11px;background:rgba(255,255,255,0.15);border-radius:3px;padding:4px 10px;">READ ONLY</span>
</div>

<!-- LEGEND -->
<div id="legend">
  <span class="legend-label">Streams:</span>
  <span class="legend-item"><span class="legend-dot" style="background:var(--col-academic-bg);border-color:var(--col-academic-border)"></span>Academic</span>
  <span class="legend-item"><span class="legend-dot" style="background:var(--col-structure-bg);border-color:var(--col-structure-border)"></span>Structure</span>
