  el.value = total + '%';
  el.style.color      = total === 100 ? '#1a5c2a' : total > 100 ? '#8b2020' : 'inherit';
  el.style.background = total === 100 ? '#e6f4ea' : total > 100 ? '#fde8e8' : 'var(--bg)';
  el.style.fontWeight = '600';
}

