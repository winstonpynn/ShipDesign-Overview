on('btn-save-json', 'click', () => {
  const data = { grid, holding, nextId, tasks, roster, taskNextId, version: '0.4', savedAt: new Date().toISOString() };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'ShipDesign_Sequencing_' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
