  const loc = selectedFromHolding ? 'Holding Area'
    : (selectedTermId ? `${selectedTermId} · ${STREAM_LABELS[selectedStream]}` : '—');
  document.getElementById('detail-meta').textContent =
    `ID: ${course.id}  ·  ${loc}` +
    (course.editedBy ? `  ·  Last edited: ${course.editedBy}${course.editedDate ? ' · ' + course.editedDate : ''}` : '');

  switchDetailTab('identity');
  document.getElementById('detail-overlay').classList.add('visible');

  // ── READ-ONLY: disable all inputs and hide editing controls ──
  document.querySelectorAll('#detail-panel input, #detail-panel select, #detail-panel textarea').forEach(el => {
    el.disabled = true;
  });
  ['btn-detail-save','btn-add-topic','btn-add-prereq','btn-add-coreq'].forEach(btnId => {
    const el = document.getElementById(btnId);
    if (el) el.style.display = 'none';
  });
  // Hide the add-topic and add-prereq/coreq input rows
  document.querySelectorAll('#detail-panel .dform-group input[id^="d-new"]').forEach(el => {
    if (el.parentElement) el.parentElement.style.display = 'none';
  });
  // Hide tag remove buttons
  document.querySelectorAll('.prereq-tag-remove').forEach(el => el.style.display = 'none');
  // Hide topic remove buttons
  document.querySelectorAll('.topic-remove').forEach(el => el.style.display = 'none');
  // Make status buttons non-interactive
  document.querySelectorAll('.status-btn').forEach(el => {
    el.style.pointerEvents = 'none';
  });
}

