  <span class="legend-item"><span class="status-dot" style="background:#1a5276"></span>Reviewed</span>
  <span class="legend-item"><span class="status-dot" style="background:#1a5c2a"></span>Approved</span>
  <span style="flex:1"></span>
  <button id="btn-open-tasks" style="background:var(--accent);color:#fff;border:none;border-radius:4px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;font-family:'IBM Plex Sans',sans-serif;margin-right:8px;">📋 View Tasks</button>
