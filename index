function renderGATable(mappings) {
  const tbody = document.getElementById('d-ga-tbody');
  tbody.innerHTML = '';
  TAC_GAS.forEach(ga => {
    const cur = mappings[ga.code] || '';
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><strong style="font-family:'IBM Plex Mono',monospace;font-size:10px;">${escHtml(ga.code)}</strong></td>
      <td style="font-size:11px;">${escHtml(ga.desc)}</td>
      <td>
        <select data-ga="${escHtml(ga.code)}">
          <option value="">—</option>
          <option value="I"  ${cur==='I'  ?'selected':''}>I — Introduced</option>
          <option value="D"  ${cur==='D'  ?'selected':''}>D — Developed</option>
          <option value="Dm" ${cur==='Dm' ?'selected':''}>Dm — Demonstrated</option>
        </select>
      </td>`;
    tbody.appendChild(tr);
  });
}

function collectGAMappings() {
  const m = {};
  document.querySelectorAll('#d-ga-tbody select').forEach(sel => {
    if (sel.value) m[sel.dataset.ga] = sel.value;
  });
  return m;
}

// ── TOPICS ──
function renderDetailTopics(topics) {
  const ul = document.getElementById('d-topics-list');
  ul.innerHTML = '';
  (topics || []).forEach((t, i) => {
    const li = document.createElement('li');
    li.innerHTML = `
      <span class="topic-drag-handle">⠿</span>
      <span style="flex:1;font-size:12px;">${escHtml(t)}</span>
      <button class="topic-remove" data-idx="${i}" title="Remove">✕</button>`;
    li.querySelector('.topic-remove').addEventListener('click', e => {
      const course = findCourse(selectedCourseId);
      if (course) { course.topics.splice(parseInt(e.target.dataset.idx), 1); renderDetailTopics(course.topics); }
    });
    ul.appendChild(li);
  });
}

