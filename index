function onBlockDragStart(e, courseId, termId, stream, idx, fromHolding) {
  dragState = { courseId, sourceTermId: termId, sourceStream: stream, sourceIndex: idx, fromHolding };
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/plain', courseId);

  // Create ghost
  const el = e.currentTarget;
  const ghost = el.cloneNode(true);
  ghost.className = el.className + ' drag-ghost';
  ghost.style.width = el.offsetWidth + 'px';
  document.body.appendChild(ghost);
  e.dataTransfer.setDragImage(ghost, 20, 20);
  dragState.ghostEl = ghost;

  setTimeout(() => { el.classList.add('dragging'); }, 0);
}

function onBlockDragEnd(e) {
  e.currentTarget.classList.remove('dragging');
  if (dragState && dragState.ghostEl) {
    dragState.ghostEl.remove();
  }
  // Clean up drag-over highlights
  document.querySelectorAll('.stream-cell').forEach(c => {
    c.classList.remove('drag-over','drag-over-occupied');
  });
  document.getElementById('holding-area').classList.remove('drag-over-holding');
  dragState = null;
}

function onCellDragOver(e) {
  if (!dragState) return;
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  const cell = e.currentTarget;
  cell.classList.remove('drag-over','drag-over-occupied');
  cell.classList.add('drag-over');
}

function onCellDragLeave(e) {
  const cell = e.currentTarget;
  if (!cell.contains(e.relatedTarget)) {
    cell.classList.remove('drag-over','drag-over-occupied');
  }
}

function onCellDrop(e) {
  e.preventDefault();
  if (!dragState) return;
  const cell = e.currentTarget;
  const targetTerm = cell.dataset.term;
  const targetStream = cell.dataset.stream;
  cell.classList.remove('drag-over','drag-over-occupied');

  const course = findCourse(dragState.courseId);
  if (!course) return;

  // Don't drop onto itself (same cell, same course already there)
  if (!dragState.fromHolding &&
      dragState.sourceTermId === targetTerm &&
      dragState.sourceStream === targetStream) return;

  // Remove from source
  removeCourseFromSource(dragState);

  // Append to target — stacking is allowed, no displacement
  grid[targetTerm][targetStream].push(course);

  // Update selection
  selectedCourseId = course.id;
  selectedTermId = targetTerm;
  selectedStream = targetStream;
  selectedFromHolding = false;

  render();
  updateEditPanel();
}

function onHoldingDragOver(e) {
  if (!dragState) return;
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  document.getElementById('holding-area').classList.add('drag-over-holding');
}
function onHoldingDragLeave(e) {
  const area = document.getElementById('holding-area');
  if (!area.contains(e.relatedTarget)) {
    area.classList.remove('drag-over-holding');
  }
}
function onHoldingDrop(e) {
  e.preventDefault();
  if (!dragState) return;
  document.getElementById('holding-area').classList.remove('drag-over-holding');

  if (dragState.fromHolding) return; // already in holding

  const course = findCourse(dragState.courseId);
  if (!course) return;

  removeCourseFromSource(dragState);
  holding.push(course);

  selectedCourseId = course.id;
  selectedTermId = null;
  selectedStream = null;
  selectedFromHolding = true;

  render();
  updateEditPanel();
}

function findCourse(id) {
  // Search grid
  for (const term of TERMS) {
    for (const stream of STREAMS) {
      const arr = grid[term.id][stream];
      const c = arr.find(x => x.id === id);
      if (c) return c;
    }
  }
  // Search holding
  return holding.find(x => x.id === id) || null;
}

function removeCourseFromSource(ds) {
  if (ds.fromHolding) {
    holding = holding.filter(x => x.id !== ds.courseId);
  } else {
    grid[ds.sourceTermId][ds.sourceStream] = grid[ds.sourceTermId][ds.sourceStream].filter(x => x.id !== ds.courseId);
  }
}


