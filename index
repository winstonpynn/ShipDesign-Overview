  .roster-remove:hover { color: var(--danger); }
  .add-member-row { display: grid; grid-template-columns: 1fr 1fr auto; gap: 8px; align-items: end; }
  .add-member-row input, .add-member-row select {
    padding: 7px 10px; border: 1px solid var(--border); border-radius: 4px;
