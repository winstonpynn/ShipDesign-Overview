    </div>
    <div class="form-actions" style="margin-top:6px;">
      <button class="btn-detail" id="btn-open-detail">Detail ▸</button>
    </div>
  </div>
</div>

<!-- TASK MANAGER OVERLAY -->
<div id="task-overlay">
  <div id="task-panel">
