// TASK MANAGER
// ═══════════════════════════════════════════════

const TASK_TYPE_LABELS = {
  'course-outline': 'Course Outline',
  'stream-review':  'Stream Review',
  'ga-mapping':     'GA Mapping',
  'other':          'Other',
};

function openTaskManager() {
