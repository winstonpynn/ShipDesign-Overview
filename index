    <div></div>
    <div class="col-header academic">Academic</div>
    <div class="col-header structure">Structure</div>
    <div class="col-header hull">Hull & Stability</div>
    <div class="col-header mechElec">Mech / Elec</div>
    <div class="col-header other">Other / Mgmt</div>
