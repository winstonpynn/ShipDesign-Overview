// ── MY TASKS tab ──
let myTasksFilter = null;

function renderMemberFilterBtns() {
  const container = document.getElementById('member-filter-btns');
  if (!container) return;
  container.innerHTML = '';
  if (roster.length === 0) {
    container.innerHTML = '<span style="font-size:12px;color:var(--text-muted);font-style:italic;">No team members in this snapshot.</span>';
    return;
  }
  roster.forEach(member => {
    const initials = member.name.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
    const btn = document.createElement('button');
    btn.style.cssText = 'display:flex;align-items:center;gap:8px;padding:6px 14px;border-radius:20px;border:2px solid var(--border);background:var(--bg);cursor:pointer;font-family:\'IBM Plex Sans\',sans-serif;font-size:12px;font-weight:600;color:var(--text-muted);transition:all 0.15s;';
    btn.innerHTML = `<span style="width:22px;height:22px;border-radius:50%;background:var(--accent);color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono',monospace;flex-shrink:0;">${escHtml(initials)}</span>${escHtml(member.name)}`;
    btn.addEventListener('click', () => {
      if (myTasksFilter === member.id) {
        myTasksFilter = null;
        btn.style.borderColor = 'var(--border)';
        btn.style.background  = 'var(--bg)';
        btn.style.color       = 'var(--text-muted)';
        renderMyTasksBoard(null);
      } else {
        myTasksFilter = member.id;
        container.querySelectorAll('button').forEach(b => {
          b.style.borderColor = 'var(--border)';
          b.style.background  = 'var(--bg)';
          b.style.color       = 'var(--text-muted)';
        });
        btn.style.borderColor = 'var(--accent)';
        btn.style.background  = 'var(--accent-light)';
        btn.style.color       = 'var(--accent)';
        renderMyTasksBoard(member.id);
      }
    });
    container.appendChild(btn);
  });
}

function renderMyTasksBoard(memberId) {
  const filtered = memberId ? tasks.filter(t => t.assigneeId === memberId) : [];
  const cols = { todo: [], inprog: [], done: [] };
  filtered.forEach(t => { if (cols[t.status]) cols[t.status].push(t); });
  ['todo','inprog','done'].forEach(status => {
    const container = document.getElementById('my-col-' + status);
    const cnt = document.getElementById('my-cnt-' + status);
    if (!container || !cnt) return;
    cnt.textContent = cols[status].length;
    container.innerHTML = '';
    cols[status].forEach(task => container.appendChild(makeReadOnlyTaskCard(task)));
  });
  const empty = document.getElementById('my-tasks-empty');
  const board  = document.getElementById('my-tasks-board');
  if (!empty || !board) return;
  if (!memberId) {
    empty.style.display = 'block';
    board.style.display = 'none';
  } else {
    empty.style.display = 'none';
    board.style.display = 'grid';
  }
}

function makeReadOnlyTaskCard(task) {
  const card = document.createElement('div');
  card.className = 'task-card type-' + task.type;
  const member = roster.find(m => m.id === task.assigneeId);
  const assigneeHtml = member
    ? `<span class="task-assignee">${escHtml(member.name)}</span>`
    : `<span class="task-assignee" style="opacity:0.5">Unassigned</span>`;
  const refHtml = task.ref ? `<span class="task-ref">${escHtml(task.ref)}</span>` : '';
  const today = new Date().toISOString().slice(0,10);
  const dueHtml = task.due
    ? `<span class="task-due ${task.due < today && task.status !== 'done' ? 'overdue' : ''}">${task.due}</span>`
    : '';
  card.innerHTML = `
    <div class="task-card-type">${escHtml(TASK_TYPE_LABELS[task.type] || task.type)}</div>
    <div class="task-card-title">${escHtml(task.title)}</div>
    ${task.desc ? `<div class="task-card-desc">${escHtml(task.desc)}</div>` : ''}
    <div class="task-card-meta">${assigneeHtml}${refHtml}${dueHtml}</div>
  `;
  return card;
}

// Override renderBoard to produce read-only cards (no move buttons)
function renderBoard() {
  const cols = { todo: [], inprog: [], done: [] };
  tasks.forEach(t => { if (cols[t.status]) cols[t.status].push(t); });
  ['todo','inprog','done'].forEach(status => {
    const container = document.getElementById('col-' + status + '-cards');
    const cnt = document.getElementById('cnt-' + status);
    if (!container || !cnt) return;
    cnt.textContent = cols[status].length;
    container.innerHTML = '';
    cols[status].forEach(task => container.appendChild(makeReadOnlyTaskCard(task)));
  });
  const open = tasks.filter(t => t.status !== 'done').length;
  const badge = document.getElementById('task-count-badge');
  if (badge) badge.textContent = tasks.length ? `${open} open · ${tasks.length} total` : '';
}

