// ── PREREQ / COREQ TAGS ──
function renderTags(containerId, items, type) {
  const container = document.getElementById(containerId);
  container.innerHTML = '';
  (items || []).forEach((item, i) => {
    const tag = document.createElement('span');
    tag.className = 'prereq-tag';
    tag.innerHTML = `${escHtml(item)}<button class="prereq-tag-remove" data-type="${type}" data-idx="${i}">✕</button>`;
    tag.querySelector('.prereq-tag-remove').addEventListener('click', e => {
      const course = findCourse(selectedCourseId);
      if (!course) return;
      const arr = e.target.dataset.type === 'prereq' ? course.prereqs : course.coreqs;
      arr.splice(parseInt(e.target.dataset.idx), 1);
      renderTags(containerId, arr, type);
    });
    container.appendChild(tag);
  });
}

