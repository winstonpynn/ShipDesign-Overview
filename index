      <label>Course Code</label>
      <input type="text" id="edit-code" placeholder="e.g. NARC 2103">
    </div>
    <div class="form-group">
      <label>Course Title</label>
      <input type="text" id="edit-title" placeholder="e.g. Ship Stability">
    </div>
    <div class="form-group hours-row">
      <div>
        <label>Lecture Hrs/Wk</label>
        <input type="number" id="edit-lect" min="0" max="10" value="3">
      </div>
      <div>
        <label>Lab Hrs/Wk</label>
        <input type="number" id="edit-lab" min="0" max="10" value="2">
      </div>
    </div>
    <div class="form-group">
      <label>Stream</label>
      <select id="edit-stream">
        <option value="academic">Academic</option>
        <option value="structure">Structure</option>
        <option value="hull">Hull & Stability</option>
        <option value="mechElec">Mech / Elec</option>
        <option value="other">Other / Mgmt</option>
